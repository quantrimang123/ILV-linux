{
  "profile": {
    "path": "desktop",
    "name": "hyprland"
  },
  "keyboard-layout": "us",
  "timezone": "Asia/Ho_Chi_Minh",
  "nic": {
    "network-configuration": "dhcp"
  },
  "disk_config": {
    "device_selection": {
      "select_disk": ["/dev/nvme0n1", "/dev/sda"],
      "partitions": [
        {
          "mountpoint": "/",
          "size": "100%",
          "type": "ext4"
        }
      ]
    },
    "wipe": true
  },
  "bootloader": "grub",
  "swap": true,
  "hostname": "ilvlinux",
  "users": [
    {
      "username": "ilvuser",
      "password": "123456",
      "sudo": true
    }
  ],
  "additional-packages": [
    "networkmanager",
    "vim",
    "git",
    "fastfetch",
    "kitty"
  ],
  "silent": true
}
