{
  "profile": { "path": "desktop", "name": "hyprland" },
  "keyboard-layout": "us",
  "timezone": "Asia/Ho_Chi_Minh",
  "nic": { "network-configuration": "dhcp" },
  "disk_layouts": [
    {
      "device": "/dev/nvme0n1",
      "config_type": "partition",
      "partitions": [
        {
          "mountpoint": "/boot/efi",
          "size": "512M",
          "type": "fat32"
        },
        {
          "mountpoint": "/",
          "size": "100%",
          "type": "ext4"
        }
      ]
    }
  ],
  "wipe": true,
  "bootloader": "grub",
  "swap": true,
  "hostname": "ilvlinux",
  "users": [
    {
      "username": "USER_PLACEHOLDER",
      "password": "PASS_PLACEHOLDER",
      "sudo": true
    }
  ],
  "additional-packages": [
    "networkmanager",
    "vim",
    "git",
    "fastfetch",
    "kitty"
  ],
  "silent": true
}
