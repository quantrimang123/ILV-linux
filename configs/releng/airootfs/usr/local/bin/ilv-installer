#!/bin/bash

# Kiểm tra quyền root
if [[ $EUID -ne 0 ]]; then
   echo "Phải chạy dưới quyền root (sudo)" 
   exit 1
fi

# Hàm tạo Menu
show_menu() {
    whiptail --title "ILV-LINUX INSTALLER" --menu "Chọn công việc bạn muốn làm:" 15 60 4 \
    "1" "Phân vùng ổ đĩa (Disk Partition)" \
    "2" "Cài đặt hệ thống cơ bản" \
    "3" "Thiết lập cấu hình mạng" \
    "4" "Thoát" 3>&1 1>&2 2>&3
}

# Vòng lặp Menu
choice=$(show_menu)
case $choice in
    1)
        # Gọi lệnh phân vùng (ví dụ cfdisk)
        cfdisk /dev/nvme0n1 || cfdisk /dev/sda
        ;;
    2)
        # Gọi lệnh pacstrap (cần cấu hình mount point trước)
        echo "Đang cài đặt..."
        pacstrap /mnt base linux linux-firmware nano
        ;;
    3)
        # Gọi script cấu hình mạng của bạn
        nmtui
        ;;
    *)
        exit 0
        ;;
esac
